{
  "name": "@miragon/sarif-report-parse",
  "version": "1.0.5",
  "private": true,
  "description": "Parses a SARIF report and logs its vulnerabilities",
  "author": "Andreas Riepl <andreas.riepl@miragon.io>",
  "homepage": "https://github.com/Miragon/sarif-report-parse",
  "bugs": {
    "url": "https://github.com/Miragon/sarif-report-parse/issues"
  },
  "license": "Apache-2.0",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "ssh://git@github.com/Miragon/sarif-report-parse.git"
  },
  "scripts": {
    "build": "eslint \"src/**/*.ts\" && tsc",
    "dist": "eslint \"src/**/*.ts\" && esbuild src/index.ts --bundle --packages=bundle --platform=node --target=node24 --format=cjs --outfile=dist/index.js --minify",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@actions/glob": "^0.6.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.0",
    "@types/sarif": "2.1.7",
    "@typescript-eslint/eslint-plugin": "8.57.2",
    "@typescript-eslint/parser": "8.57.2",
    "esbuild": "0.27.4",
    "eslint": "10.1.0",
    "eslint-plugin-import": "2.32.0",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": "*"
  }
}
